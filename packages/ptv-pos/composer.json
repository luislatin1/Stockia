{
  "name": "stockia/ptv-pos",
  "description": "PTV-POS module for Stockia",
  "type": "library",
  "license": "proprietary",
  "version": "0.1.0",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/database": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Stockia\\PTVPos\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stockia\\PTVPos\\Providers\\PTVPosServiceProvider"
      ]
    },
    "stockia": {
      "module_key": "ptv-pos"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

