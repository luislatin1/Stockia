{
  "name": "stockia/sales-quotes",
  "description": "Sales quotes module for Stockia",
  "type": "library",
  "license": "proprietary",
  "version": "0.1.0",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/database": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Stockia\\SalesQuotes\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stockia\\SalesQuotes\\Providers\\SalesQuotesServiceProvider"
      ]
    },
    "stockia": {
      "module_key": "sales-quotes"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
